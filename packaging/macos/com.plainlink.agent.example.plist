<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.plainlink.agent</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/plainlink</string>
    <string>watch</string>
    <string>--interval-ms</string>
    <string>500</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/plainlink.out.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/plainlink.err.log</string>
</dict>
</plist>
